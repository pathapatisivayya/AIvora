[Unit]
Description=Aivora Django API (Gunicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/AIvora/backend
Environment=DJANGO_SETTINGS_MODULE=config.settings
Environment=PATH=/home/ubuntu/AIvora/backend/.venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/ubuntu/AIvora/backend/.venv/bin/gunicorn -c gunicorn.conf.py config.wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
