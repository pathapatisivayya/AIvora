# Browser calls use same-origin /api in dev (Vite proxy). Override for explicit API host:
# VITE_API_URL=http://localhost:8000/api

# Local backend (default for dev):
VITE_PROXY_API=http://127.0.0.1:8000

# EC2 backend (public IP — use when your API runs on the instance, e.g. port 8000):
# VITE_PROXY_API=http://107.23.239.129:8000
# VITE_API_URL=http://107.23.239.129:8000/api

# Internal VPC-only builds (e.g. bastion → private IP):
# VITE_PROXY_API=http://172.31.38.134:8000
# VITE_API_URL=http://172.31.38.134:8000/api

# Duck DNS (same host for UI + /api behind nginx — leave unset; use below if API is another port/host):
# VITE_API_URL=https://aivora.duckdns.org/api
