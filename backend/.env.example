DJANGO_SECRET_KEY=replace-with-long-random-string
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings
# Comma-separated: Duck DNS hostname, EC2 public IP, private IP, public DNS, local dev.
DJANGO_ALLOWED_HOSTS=aivora.duckdns.org,107.23.239.129,172.31.38.134,ec2-107-23-239-129.compute-1.amazonaws.com,localhost,127.0.0.1

# --- Database (default: SQLite, no RDS) ---
USE_SQLITE=True
# Local: leave unset (uses backend/db.sqlite3). On AWS EC2 use a persistent path, e.g.:
# SQLITE_PATH=/var/lib/aivora/db.sqlite3

# PostgreSQL/RDS: USE_SQLITE=False and set DB_*.
# USE_SQLITE=False
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=aivora
# DB_USER=aivora
# DB_PASSWORD=secret
# DB_HOST=localhost
# DB_PORT=5432

CORS_ALLOW_ALL_ORIGINS=False
# Match browser origins (scheme + host + port). Add your domain when you use HTTPS.
CORS_ALLOWED_ORIGINS=http://aivora.duckdns.org,http://aivora.duckdns.org:8000,https://aivora.duckdns.org,http://107.23.239.129,http://107.23.239.129:8000,http://172.31.38.134,http://ec2-107-23-239-129.compute-1.amazonaws.com,http://localhost:5173,http://127.0.0.1:5173

# Full origins with scheme (needed for HTTPS admin / session CSRF). Match how users open the site.
DJANGO_CSRF_TRUSTED_ORIGINS=http://aivora.duckdns.org,http://aivora.duckdns.org:8000,https://aivora.duckdns.org

# Plain HTTP on :8000 only (before nginx + HTTPS). Uncomment for that setup; remove or set True when using TLS.
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# No S3: uploads stay on disk (MEDIA_ROOT). Set USE_S3=True only if you add a bucket later.
USE_S3=False

CONTACT_EMAIL_TO=hello@aivorasolutions.com
WHATSAPP_NUMBER=9195532000352
# Gmail App Password: 16 chars, no spaces, no quotes — EMAIL_HOST_PASSWORD=abcdabcdabcdabcd

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=youraddress@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL="Your Name <youraddress@gmail.com>"

# Production on AWS: set DJANGO_DEBUG=False. For HTTPS behind nginx, keep SECURE_SSL_REDIRECT=True (default) and secure cookies True.
